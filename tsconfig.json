{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    /* 模块系统配置 */
    "module": "ESNext",                    // 使用最新的ES模块语法
    "moduleResolution": "bundler",         // 使用打包工具的模块解析策略
    "noEmit": true,                        // 不生成编译输出(仅类型检查)
    
    /* TypeScript扩展支持 */
    "allowImportingTsExtensions": true,    // 允许导入.ts/.tsx文件
    
    /* JSON模块支持 */
    "resolveJsonModule": true,             // 允许导入JSON文件(用于配置文件)
    
    /* 互操作性 */
    "esModuleInterop": true,               // 启用ES模块与CommonJS互操作
    
    /* 编译优化 */
    "skipLibCheck": true                   // 跳过类型声明文件检查(提升编译速度)
  }
}
